[Unit]
Description=SoulPulse Backend API
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/Documents/SoulPulse/backend
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
StandardOutput=append:/var/log/soulpulse_backend.log
StandardError=append:/var/log/soulpulse_backend.log

[Install]
WantedBy=multi-user.target
