# SoulPulse Environment Configuration Template
# Copy this file to .env and fill in your keys

DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_CHAT_MODEL=qwen-max
DASHSCOPE_CHARACTER_MODEL=qwen2.5-role-play
DASHSCOPE_IMAGE_MODEL=wanx2.1-t2i-turbo
DASHSCOPE_VIDEO_MODEL=wanx-v1

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=soulpulse-media
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

SECRET_KEY=change-me-in-production-use-a-real-secret

# CORS allowed origins (comma-separated, "*" for dev)
ALLOWED_ORIGINS=*
